# Database and queue
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/telegram_outreach
REDIS_URL=redis://redis:6379/0

# Docker Compose host bindings
# Use distinct COMPOSE_PROJECT_NAME, API_HOST_PORT, and POSTGRES_HOST_PORT values per VPS environment.
COMPOSE_PROJECT_NAME=telegram-outreach
API_HOST_BIND=0.0.0.0
API_HOST_PORT=8000
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432

# Bot-to-API auth and routing
BOT_API_TOKEN=replace-with-shared-api-token
BOT_API_BASE_URL=http://api:8000/api
BOT_API_TIMEOUT_SECONDS=15
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_ALLOWED_USER_IDS=

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BRIEF_MODEL=gpt-4o-mini

# Telegram account access
TELEGRAM_API_ID=replace-with-telegram-api-id
TELEGRAM_API_HASH=replace-with-telegram-api-hash
SESSIONS_DIR=/sessions
TELEGRAM_MEMBER_IMPORT_LIMIT=10000

# Collection scheduling
COLLECTION_INTERVAL_MINUTES=60

# Engagement scheduling
ENGAGEMENT_DETECTION_WINDOW_MINUTES=60
ENGAGEMENT_SCHEDULER_INTERVAL_SECONDS=3600
